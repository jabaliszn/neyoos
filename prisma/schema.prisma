model NeyoFounderOpsEntry {
  id              String    @id @default(cuid())
  kind            String // WEEKLY_METRICS | MONTHLY_ALL_HANDS | QUARTERLY_AUDIT | ANNUAL_PLANNING | DEMO_DAY | INVESTOR_UPDATE | BOARD_MEETING | IMPACT_REPORT
  periodKey       String? // YYYY-W##, YYYY-MM, YYYY-Q#, YYYY, or event slug
  title           String
  status          String    @default("PLANNED") // PLANNED | DONE | SKIPPED
  scheduledFor    String? // YYYY-MM-DD
  completedAt     DateTime?
  summary         String?
  notes           String?
  decisionsJson   String? // JSON array of decisions made
  actionItemsJson String? // JSON array of {task, owner, dueOn, done}
  metricsJson     String? // JSON metrics snapshot relevant to this meeting/update
  audience        String? // internal, investors, board, community, public
  createdById     String?
  createdByName   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([kind, periodKey])
  @@index([kind, status])
  @@index([scheduledFor])
}

model NeyoCustomerInterview {
  id                String   @id @default(cuid())
  schoolName        String
  contactName       String
  contactRole       String? // Principal, Bursar, Parent, Teacher, etc.
  phone             String?
  email             String?
  county            String?
  interviewDate     String // YYYY-MM-DD
  channel           String   @default("CALL") // CALL | VISIT | WHATSAPP | VIDEO
  status            String   @default("SCHEDULED") // SCHEDULED | DONE | CANCELLED
  painPointsJson    String? // JSON array
  quotesJson        String? // JSON array of exact customer quotes
  opportunitiesJson String? // JSON array of product/commercial opportunities
  followUp          String?
  createdById       String?
  createdByName     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([interviewDate])
  @@index([status])
  @@index([schoolName])
}

// ---- Leaving Certificate Vault (H.3) ---------------------------------------
model LeavingCertificate {
  id               String    @id @default(cuid())
  tenantId         String
  studentId        String    @unique
  student          Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  certificateType  String // "KCPE" | "KCSE" | "OTHER"
  certificateNo    String    @unique
  status           String    @default("STORED") // STORED | HANDED_OVER
  fileUrl          String? // scanned copy upload (optional)
  fileName         String?
  hardcopyLocation String    @default("Unspecified") // physical location of the hardcopy certificate (H.3) - MANDATORY!
  handedOverTo     String? // who physically took it (e.g. Student, Parent)
  handedOverAt     DateTime? // exact date and time of handover
  handedOverById   String? // staff who did the handover
  handedOverByName String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenantId])
}

// ---- Entrance Exam Paper Vault (H.3 / I.11) ---------------------------------
// One printable interview/entrance paper per actual class/stream, managed from
// Admissions so staff do not dig through files during new-student interviews.
model EntranceExamPaper {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classId          String? // SchoolClass.id; nullable only for old migrated level-only rows
  classLevel       String // legacy/display fallback, e.g. "Form 1"
  classLabel       String // exact class display, e.g. "Form 1 East"
  title            String    @default("Entrance interview paper")
  fileUrl          String
  fileName         String
  hardcopyLocation String    @default("Admissions office file")
  uploadedById     String?
  uploadedBy       String?
  printCount       Int       @default(0)
  lastPrintedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([tenantId, classId])
  @@index([tenantId, classLabel])
}
