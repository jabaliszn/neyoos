// NEYO database schema — Chunk 0 Foundation
// Dev provider: sqlite (file-based, zero-install, testable in preview today).
// Production: change provider to "postgresql" and point DATABASE_URL at Neon.
//   Postgres-only features flagged in code: Row-Level Security (A.2), tsvector search (A.11).
// Each feature chunk EXTENDS this schema with its own models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// The 16 roles (Part A.3). SQLite has no native enums, so we store the role as
// a string and validate it against this list in Zod (Chunk 2 of every feature).
// Canonical role list lives in src/lib/core/roles.ts.
// ---------------------------------------------------------------------------

// A school / business / farm / creator account = one Tenant (A.2 Multi-Tenancy).
model Tenant {
  id     String  @id @default(cuid())
  name   String
  slug   String  @unique // used for subdomain + ID prefix (A.4)
  county String? // Kenyan county, e.g. "Nairobi"
  phone  String? // +254 7XX XXX XXX
  email  String?
  osKey  String  @default("school") // I.50: school | business | farm | creator

  // Onboarding (G.3)
  curriculum           String? // "CBC" | "8-4-4" | "BOTH"
  onboardedAt          DateTime?
  // G.14 Day-One Demo Mode: a sandboxed, time-boxed tenant that auto-expires.
  isDemo               Boolean   @default(false)
  demoExpiresAt        DateTime? // when the demo tenant is purged (null = not a demo / kept)
  // G.21 (founder 2026-06-12): DAY | BOARDING | DAY_AND_BOARDING — gates the
  // hostel module + boarding-fee features for day-only schools.
  schoolType           String    @default("DAY")
  // G.24 uniform supplier/tailor (orders are relayed to them).
  uniformSupplierName  String?
  uniformSupplierPhone String? // +254...

  // Calendar preferences (A.17.3): opt-in to showing religious moments.
  showReligiousHolidays Boolean @default(true)
  libraryFinesEnabled   Boolean @default(true) // customizable switch for late book returns fines (H.3)
  libraryFinePerDayKes  Int     @default(10) // customizable late-return fine amount per chargeable day

  // School Profile & Branding (G.9). Used across receipts/reports/ID cards and
  // (later) the public subdomain landing site (G.11).
  motto               String?
  vision              String?
  mission             String?
  about               String? // short description / "about us"
  logoUrl             String? // school badge/logo (stored via A.9)
  brandPrimary        String? // hex, e.g. "#1c2740"
  brandAccent         String? // hex, e.g. "#1f9d5f"
  addressLine         String? // postal/physical address
  socialLinks         String? // JSON: { facebook, instagram, tiktok, youtube, website }
  // Joining requirements MASTER list (G.9): JSON array of
  // { label, category, quantity?, mandatory } shown to new parents at admission.
  joiningRequirements String?
  documentDesignJson  String? // I.42 school-owned document/ID design defaults
  // G.17 geofence for GPS-verified staff clock-in (null = geofence off).
  gpsLat              Float?
  gpsLng              Float?
  gpsRadiusM          Int? // allowed distance from the gate, metres (e.g. 300)

  // B.24 Owner Dashboard: fee-collection target the owner measures against.
  collectionTargetPct         Int @default(85) // % of billed fees expected collected this term
  // B.25 Procurement: POs above this need leadership approval (KES).
  poApprovalThresholdKes      Int @default(50000)
  // B.25 Expenses: expenses above this need leadership approval (KES).
  expenseApprovalThresholdKes Int @default(20000)
  // G.12 Sibling Intelligence: default % discount applied to a sibling's fee
  // invoice when a family has 2+ children enrolled (0 = off; bursar applies it).
  siblingDiscountPct          Int @default(0)

  // G.34 Security Hardening: enforce 2FA for all leadership/staff roles
  enforce2Fa Boolean @default(false)

  // H.2 Multi-Owner Support: when a school has 2+ owners and this is ON, certain
  // critical actions need a SECOND owner's approval (dual control) — every
  // decision is logged. Auto-no-ops when there's only one owner.
  requireJointOwnerApproval Boolean @default(false)

  // H.2 Customized Printing Limits: max document prints per user per day for
  // non-privileged roles (null/0 = unlimited). Privileged roles (Principal,
  // Deputy, Academics HOD, Owner) bypass the limit and set it.
  printLimitPerDay Int? @default(0)

  // H.2 Boarding Term-End Print Scheduler: "AUTO" = the print station prints
  // jobs as they queue (default); "HOLD" = boarding schools hold all jobs and
  // batch-print them only at term end. School-wide, leadership-controlled.
  printStationMode String @default("AUTO")

  // H.5 Cafeteria Table Allocation: default number of seats per dining table.
  cafeteriaTableSize Int    @default(8)
  cafeteriaMealModel String @default("HYBRID") // HYBRID | CARDS_ONLY | BOARDING_GROUPS | NO_CARDS
  cafeteriaMealScope String @default("ALL") // ALL | LUNCH | SUPPER

  // H.2 Role-Based Settings & Module Visibility Control: per-school map of which
  // nav items / settings are HIDDEN for which roles. JSON: { "<href>": ["ROLE",..] }.
  // Owner/Principal-managed; non-concerned staff can be reduced to just their
  // own Security (password) + language. Empty/null = nothing extra hidden.
  navVisibility String?

  // Per-tenant encryption key (A.2.7, DEK/KEK envelope pattern).
  // The tenant's DEK is AES-256-GCM-encrypted with the master KEK (env/KMS).
  encryptedDek String? // base64 wrapped DEK
  dekIv        String? // base64 IV used to wrap the DEK
  dekTag       String? // base64 GCM auth tag for the wrapped DEK

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                     User[]
  idSequences               IdSequence[]
  auditLogs                 AuditLog[]
  modules                   TenantModule[]
  subscription              Subscription?
  usageCounters             UsageCounter[]
  paymentCredential         PaymentCredential?
  payments                  Payment[]
  notifications             Notification[]
  webPushSubscriptions      WebPushSubscription[]
  messageAcknowledgements   MessageAcknowledgement[]
  messageDeliveryReports    MessageDeliveryReport[]
  intercomCalls             IntercomCall[]
  notificationTemplates     NotificationTemplate[]
  conversations             Conversation[]
  storedFiles               StoredFile[]
  storageProvider           TenantStorageProvider?
  storageUsageSnapshots     StorageUsageSnapshot[]
  documentVerifications     DocumentVerification[]
  apiKeys                   ApiKey[]
  webhookSubscriptions      WebhookSubscription[]
  webhookDeliveries         WebhookDelivery[]
  calendarEvents            CalendarEvent[]
  visitorLogs               VisitorLog[]
  admissionInquiries        AdmissionInquiry[]
  phoneMessages             PhoneMessage[]
  schoolClasses             SchoolClass[]
  students                  Student[]
  guardians                 Guardian[]
  studentImports            StudentImport[]
  studentTransfers          StudentTransfer[]
  attendanceRecords         AttendanceRecord[]
  principalDelegationTasks  PrincipalDelegationTask[]
  promotionRuns             PromotionRun[]
  admissionApplications     AdmissionApplication[]
  staffAttendance           StaffAttendance[]
  departments               Department[]
  subjects                  Subject[]
  academicTerms             AcademicTerm[]
  curricula                 Curriculum[]
  educationLevels           EducationLevel[]
  gradeBands                GradeBand[]
  learningAreas             LearningArea[]
  timetableSlots            TimetableSlot[]
  dutyRosterEntries         DutyRosterEntry[]
  lessonPlans               LessonPlan[]
  homework                  Homework[]
  classNotes                ClassNote[]
  homeworkSubmissions       HomeworkSubmission[]
  quizzes                   Quiz[]
  forumThreads              ForumThread[]
  bulkMessages              BulkMessage[]
  teacherCommsApprovals     TeacherCommsApprovalRequest[]
  libraryBooks              LibraryBook[]
  bookIssues                BookIssue[]
  hostels                   Hostel[]
  hostelAttendance          HostelAttendance[]
  transportRoutes           TransportRoute[]
  drivers                   Driver[]
  vehicles                  Vehicle[]
  gpsBusLocations           GpsBusLocation[]
  cctvCameras               CctvCamera[]
  hardwareDeviceConnections HardwareDeviceConnection[]
  stores                    Store[]
  assets                    Asset[]
  mealPlanEntries           MealPlanEntry[]
  mealCards                 MealCard[]
  cafeteriaTables           CafeteriaTable[]
  cafeteriaQueueEntries     CafeteriaQueueEntry[]
  uniformOrders             UniformOrder[]
  uniformSizes              UniformSize[]
  assetMaintenance          AssetMaintenance[]
  suppliers                 Supplier[]
  supplierContracts         SupplierContract[]
  purchaseRequests          PurchaseRequest[]
  purchaseQuotes            PurchaseQuote[]
  purchaseOrders            PurchaseOrder[]
  expenseCategories         ExpenseCategory[]
  costCenters               CostCenter[]
  expenses                  Expense[]
  disciplineIncidents       DisciplineIncident[]
  suspensions               Suspension[]
  counselingNotes           CounselingNote[]
  studentMedical            StudentMedical[]
  clinicVisits              ClinicVisit[]
  medicationPlans           MedicationPlan[]
  printJobs                 PrintJob[]
  printApprovalRequests     PrintApprovalRequest[]
  gatePasses                GatePass[]
  pickupPersons             PickupPerson[]
  altPickupAuthorizations   AltPickupAuthorization[]
  ownerApprovalRequests     OwnerApprovalRequest[]
  panicAlerts               PanicAlert[]
  exams                     Exam[]
  examResults               ExamResult[]
  examReleaseApprovals      ExamReleaseApprovalRequest[]
  assessmentTypes           AssessmentType[]
  assessmentPlans           AssessmentPlan[]
  assessmentRecords         AssessmentRecord[]
  assessmentEvidence        AssessmentEvidence[]
  competencyGroups          CompetencyGroup[]
  competencies              Competency[]
  competencyEvidence        CompetencyEvidence[]
  cbcStrands                CbcStrand[]
  cbcAssessments            CbcAssessment[]
  feeStructures             FeeStructure[]
  invoices                  Invoice[]
  staffSalaries             StaffSalary[]
  payrollRuns               PayrollRun[]
  staffProfiles             StaffProfile[]
  leaveRequests             LeaveRequest[]
  jobPostings               JobPosting[]
  appraisals                Appraisal[]
  disciplinaryRecords       DisciplinaryRecord[]
  trainingRecords           TrainingRecord[]
  termPulses                TermPulse[]
  savedViews                SavedView[]
  teacherSubjects           TeacherSubject[]
  classSubjectNeeds         ClassSubjectNeed[]
  timetableConfigs          TimetableConfig[]
  onlineClassSessions       OnlineClassSession[]
  onlineClassParticipants   OnlineClassParticipant[]
  onlineClassSignals        OnlineClassSignal[]
  onlineClassQuestions      OnlineClassQuestion[]
  learningVideos            LearningVideo[]
  learningVideoSessions     LearningVideoSession[]
  classVoiceRooms           ClassVoiceRoom[]
  classVoiceParticipants    ClassVoiceParticipant[]
  classVoiceSignals         ClassVoiceSignal[]
  syllabusTopics            SyllabusTopic[]
  examTimetableSlots        ExamTimetableSlot[]
  examMaterialRecords       ExamMaterialRecord[]
  promisesToPay             PromiseToPay[]
  reportCardDayCheckIns     ReportCardDayCheckIn[]
  newsPosts                 NewsPost[]
  publicSiteSettings        PublicSiteSettings?
  publicSiteLeaders         PublicSiteLeader[]
  publicSiteTestimonials    PublicSiteTestimonial[]
  publicSiteGalleryImages   PublicSiteGalleryImage[]
  publicSiteActivities      PublicSiteActivity[]
  entranceExamPapers        EntranceExamPaper[] // Added for entrance exam papers (H.3)

  @@index([osKey])
